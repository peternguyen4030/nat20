datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

/////////////////////////////////////////////////
// USER & CAMPAIGN
/////////////////////////////////////////////////

enum UserRole {
  USER
  ADMIN
}

model User {
  id            String   @id @default(uuid())
  name          String?
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  passwordHash  String?
  displayName   String?
  avatarUrl     String?
  bio           String?
  role          UserRole @default(USER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  campaignsOwned Campaign[]       @relation("CampaignOwner")
  memberships    CampaignMember[]
  characters     Character[]
  sessions       Session[]
  accounts       Account[]
  actionLogs     ActionLog[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(uuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

model Campaign {
  id           String    @id @default(uuid())
  name         String
  description  String?
  emoji        String?
  bannerUrl    String?
  ownerId      String
  inviteCode   String?   @unique
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastPlayedAt DateTime?

  owner      User             @relation("CampaignOwner", fields: [ownerId], references: [id])
  members    CampaignMember[]
  characters Character[]
  sessions   CombatSession[]
  actionLogs ActionLog[]
  board      CampaignBoard?
  assets     CampaignAsset[]
  npcs       NPC[]

  @@index([ownerId])
}

model CampaignMember {
  id         String             @id @default(uuid())
  campaignId String
  userId     String
  role       CampaignMemberRole @default(PLAYER)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId])
  @@index([campaignId])
  @@index([userId])
}

enum CampaignMemberRole {
  DM
  PLAYER
}

/////////////////////////////////////////////////
// ACTION LOG
/////////////////////////////////////////////////

model ActionLog {
  id          String        @id @default(uuid())
  campaignId  String
  sessionId   String? // null for campaign-level actions
  userId      String
  characterId String?
  actionType  LogActionType
  description String
  result      String?
  createdAt   DateTime      @default(now())

  campaign  Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  session   CombatSession? @relation(fields: [sessionId], references: [id])
  user      User           @relation(fields: [userId], references: [id])
  character Character?     @relation(fields: [characterId], references: [id])

  @@index([campaignId])
  @@index([sessionId])
  @@index([userId])
}

enum LogActionType {
  COMBAT_ATTACK
  COMBAT_SPELL
  COMBAT_MOVE
  COMBAT_OTHER
  LEVEL_UP
  INSPIRATION_AWARDED
  INSPIRATION_SPENT
  HP_CHANGE
  CAMPAIGN_EVENT
}

/////////////////////////////////////////////////
// CHARACTER CORE
/////////////////////////////////////////////////

model Character {
  id               String  @id @default(uuid())
  name             String
  level            Int     @default(1)
  maxHp            Int
  currentHp        Int
  temporaryHp      Int     @default(0)
  armorClass       Int     @default(10)
  proficiencyBonus Int     @default(2)
  speed            Int     @default(30)
  initiative       Int     @default(0)
  inspiration      Boolean @default(false)
  isActive         Boolean @default(false)
  avatarUrl        String?
  backgroundId     String?
  gender           String?
  pronouns         String?
  notes            String?

  personalityTrait String?
  ideal            String?
  bond             String?
  flaw             String?

  deathSaves Json?
  hitDice    Json?
  spellSlots Json?

  savingThrowBonuses Json?
  skillBonuses       Json?

  languages  String[]    @default([])
  conditions Condition[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId     String
  campaignId String
  raceId     String?

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign   Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  race       Race?       @relation(fields: [raceId], references: [id])
  background Background? @relation(fields: [backgroundId], references: [id])

  abilityScores   AbilityScore?
  classes         CharacterClass[]
  features        CharacterFeature[]
  inventory       CharacterItem[]
  proficiencies   CharacterProficiency[]
  spells          CharacterSpell[]
  actionsAsActor  CombatAction[]         @relation("Actor")
  actionsAsTarget CombatAction[]         @relation("Target")
  actionLogs      ActionLog[]

  @@index([userId])
  @@index([campaignId])
  @@index([raceId])
  @@index([backgroundId])
}

enum Condition {
  BLINDED
  CHARMED
  DEAFENED
  EXHAUSTION
  FRIGHTENED
  GRAPPLED
  INCAPACITATED
  INVISIBLE
  PARALYZED
  PETRIFIED
  POISONED
  PRONE
  RESTRAINED
  STUNNED
  UNCONSCIOUS
}

/////////////////////////////////////////////////
// ABILITY SCORES
/////////////////////////////////////////////////

model AbilityScore {
  id          String @id @default(uuid())
  characterId String @unique

  strength     Int @default(10)
  dexterity    Int @default(10)
  constitution Int @default(10)
  intelligence Int @default(10)
  wisdom       Int @default(10)
  charisma     Int @default(10)

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

/////////////////////////////////////////////////
// RACE & FEATURES
/////////////////////////////////////////////////

model Race {
  id          String  @id @default(uuid())
  index       String  @unique
  name        String
  speed       Int     @default(30)
  size        String?
  description String?

  abilityBonuses Json?
  traitNames     String[]

  characters Character[]
  features   Feature[]
  subraces   Subrace[]
}

model Subrace {
  id          String  @id @default(uuid())
  index       String  @unique
  name        String
  raceId      String
  description String?

  abilityBonuses Json?

  race Race @relation(fields: [raceId], references: [id], onDelete: Cascade)

  @@index([raceId])
}

model Feature {
  id          String      @id @default(uuid())
  index       String?     @unique
  name        String
  description String
  type        FeatureType

  category     ActionCategory?
  actionType   ActionType?
  combatUsable Boolean         @default(false)

  raceId  String?
  classId String?

  race  Race?  @relation(fields: [raceId], references: [id])
  class Class? @relation(fields: [classId], references: [id])

  characters CharacterFeature[]

  @@index([raceId])
  @@index([classId])
}

enum FeatureType {
  CLASS
  RACE
  FEAT
  BACKGROUND
}

enum ActionCategory {
  ATTACK
  DAMAGING
  HEALING
  SUPPORT
  DEFENSIVE
  MOVEMENT
  UTILITY
}

enum ActionType {
  ACTION
  BONUS_ACTION
  REACTION
  FREE
  PASSIVE
}

model CharacterFeature {
  id          String @id @default(uuid())
  characterId String
  featureId   String

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  feature   Feature   @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([characterId, featureId])
}

/////////////////////////////////////////////////
// CLASS
/////////////////////////////////////////////////

model Class {
  id                  String  @id @default(uuid())
  index               String  @unique
  name                String
  hitDie              Int
  spellcastingAbility String?

  features   Feature[]
  characters CharacterClass[]
  subclasses Subclass[]
}

model Subclass {
  id      String @id @default(uuid())
  index   String @unique
  name    String
  classId String

  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([classId])
}

model CharacterClass {
  id          String @id @default(uuid())
  characterId String
  classId     String
  level       Int    @default(1)

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  class     Class     @relation(fields: [classId], references: [id])

  @@unique([characterId, classId])
}

/////////////////////////////////////////////////
// BACKGROUND
/////////////////////////////////////////////////

model Background {
  id          String  @id @default(uuid())
  index       String  @unique
  name        String
  description String?
  feature     String?

  skillProficiencies String[]
  languages          Int      @default(0)

  characters Character[]
}

/////////////////////////////////////////////////
// PROFICIENCIES
/////////////////////////////////////////////////

model Proficiency {
  id    String @id @default(uuid())
  index String @unique
  name  String
  type  String

  characters CharacterProficiency[]
}

model CharacterProficiency {
  id            String  @id @default(uuid())
  characterId   String
  proficiencyId String
  expertise     Boolean @default(false)

  character   Character   @relation(fields: [characterId], references: [id], onDelete: Cascade)
  proficiency Proficiency @relation(fields: [proficiencyId], references: [id])

  @@unique([characterId, proficiencyId])
  @@index([characterId])
}

/////////////////////////////////////////////////
// SPELLS
/////////////////////////////////////////////////

model Spell {
  id           String        @id @default(uuid())
  index        String        @unique
  name         String
  level        Int
  school       String
  castingTime  String
  range        String
  duration     String
  description  String
  higherLevels String?
  damageDice   String?
  damageType   String?
  healingDice  String?
  scalingDice  String?
  category     SpellCategory @default(UTILITY)

  characters    CharacterSpell[]
  combatActions CombatAction[]
}

enum SpellCategory {
  DAMAGING
  HEALING
  CONTROL
  BUFF
  DEBUFF
  UTILITY
  DEFENSE
}

model CharacterSpell {
  id          String               @id @default(uuid())
  characterId String
  spellId     String
  status      CharacterSpellStatus @default(KNOWN)

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  spell     Spell     @relation(fields: [spellId], references: [id])

  @@unique([characterId, spellId])
  @@index([characterId])
}

enum CharacterSpellStatus {
  KNOWN
  PREPARED
}

/////////////////////////////////////////////////
// ITEMS & INVENTORY
/////////////////////////////////////////////////

model Item {
  id          String   @id @default(uuid())
  index       String   @unique
  name        String
  description String?
  type        ItemType
  weight      Float?
  cost        String?

  damageDice  String?
  damageType  String?
  weaponRange String?
  armorClass  Int?

  characters CharacterItem[]
}

enum ItemType {
  WEAPON
  ARMOR
  CONSUMABLE
  TOOL
  GEAR
  MAGIC_ITEM
}

model CharacterItem {
  id          String  @id @default(uuid())
  characterId String
  itemId      String?
  quantity    Int     @default(1)
  equipped    Boolean @default(false)
  attuned     Boolean @default(false)

  customName        String?
  customDescription String?
  customType        String?

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  item      Item?     @relation(fields: [itemId], references: [id])

  @@unique([characterId, itemId])
  @@index([characterId])
}

/////////////////////////////////////////////////
// COMBAT
/////////////////////////////////////////////////

model CombatSession {
  id         String   @id @default(uuid())
  campaignId String
  active     Boolean  @default(true)
  round      Int      @default(1)
  createdAt  DateTime @default(now())

  currentTurnCharacterId String?
  actionUsed             Boolean @default(false)
  bonusActionUsed        Boolean @default(false)
  reactionUsed           Boolean @default(false)

  campaign   Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  actions    CombatAction[]
  actionLogs ActionLog[]

  @@index([campaignId])
  @@index([active])
}

model CombatAction {
  id          String           @id @default(uuid())
  sessionId   String
  actorId     String
  targetId    String?
  actionType  CombatActionType
  actionSlot  ActionSlot       @default(ACTION)
  spellId     String?
  npcActorId  String?
  npcTargetId String?
  attackRoll  Int?
  damageDealt Int?
  notes       String?
  createdAt   DateTime         @default(now())

  session   CombatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  actor     Character     @relation("Actor", fields: [actorId], references: [id])
  target    Character?    @relation("Target", fields: [targetId], references: [id])
  spell     Spell?        @relation(fields: [spellId], references: [id])
  npcActor  NPC?          @relation("NPCActor", fields: [npcActorId], references: [id])
  npcTarget NPC?          @relation("NPCTarget", fields: [npcTargetId], references: [id])

  @@index([sessionId])
  @@index([actorId])
  @@index([targetId])
  @@index([npcActorId])
  @@index([npcTargetId])
}

enum ActionSlot {
  ACTION
  BONUS_ACTION
  REACTION
  FREE
}

enum CombatActionType {
  ATTACK
  CAST
  DASH
  DODGE
  HELP
  HIDE
  READY
  OTHER
}

/////////////////////////////////////////////////
// CAMPAIGN BOARD
/////////////////////////////////////////////////

model CampaignBoard {
  id           String   @id @default(uuid())
  campaignId   String   @unique
  activeMapId  String?
  boardState   Json? // positions, tokens, annotations
  combatActive Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  campaign  Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  activeMap CampaignAsset? @relation(fields: [activeMapId], references: [id])

  @@index([campaignId])
}

/////////////////////////////////////////////////
// CAMPAIGN ASSETS (maps, tokens)
/////////////////////////////////////////////////

model CampaignAsset {
  id         String            @id @default(uuid())
  campaignId String
  name       String
  url        String // uploaded via Uploadthing
  type       CampaignAssetType
  createdAt  DateTime          @default(now())

  campaign Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  boards   CampaignBoard[]

  @@index([campaignId])
}

enum CampaignAssetType {
  MAP
  TOKEN
}

/////////////////////////////////////////////////
// NPC / MONSTER
/////////////////////////////////////////////////

model NPC {
  id                 String  @id @default(uuid())
  campaignId         String
  name               String
  maxHp              Int
  currentHp          Int
  armorClass         Int     @default(10)
  speed              Int     @default(30)
  initiativeModifier Int     @default(0)
  avatarUrl          String? // token image

  // Ability scores
  strength     Int @default(10)
  dexterity    Int @default(10)
  constitution Int @default(10)
  intelligence Int @default(10)
  wisdom       Int @default(10)
  charisma     Int @default(10)

  // Attacks — JSON array for flexibility
  // e.g. [{ name: "Shortsword", toHit: 4, damageDice: "1d6", damageType: "piercing" }]
  attacks Json?

  conditions Condition[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  campaign        Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  actionsAsActor  CombatAction[] @relation("NPCActor")
  actionsAsTarget CombatAction[] @relation("NPCTarget")

  @@index([campaignId])
}
