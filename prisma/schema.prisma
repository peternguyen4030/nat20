datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

/////////////////////////////////////////////////
// USER & CAMPAIGN
/////////////////////////////////////////////////

model User {
  id            String   @id @default(uuid())
  name          String?
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  passwordHash  String?
  displayName   String?
  avatarUrl     String? // uploaded via Uploadthing
  bio           String? // short profile bio
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  campaignsOwned Campaign[]       @relation("CampaignOwner")
  memberships    CampaignMember[]
  characters     Character[]
  sessions       Session[]
  accounts       Account[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(uuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

model Campaign {
  id           String    @id @default(uuid())
  name         String
  description  String?
  emoji        String?
  bannerUrl    String? // uploaded via Uploadthing
  ownerId      String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastPlayedAt DateTime?

  owner      User             @relation("CampaignOwner", fields: [ownerId], references: [id])
  members    CampaignMember[]
  characters Character[]
  sessions   CombatSession[]

  @@index([ownerId])
}

model CampaignMember {
  id         String             @id @default(uuid())
  campaignId String
  userId     String
  role       CampaignMemberRole @default(PLAYER)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId])
  @@index([campaignId])
  @@index([userId])
}

enum CampaignMemberRole {
  DM
  PLAYER
}

/////////////////////////////////////////////////
// CHARACTER CORE
/////////////////////////////////////////////////

model Character {
  id               String  @id @default(uuid())
  name             String
  level            Int     @default(1)
  maxHp            Int
  currentHp        Int
  temporaryHp      Int     @default(0)
  armorClass       Int     @default(10)
  proficiencyBonus Int     @default(2)
  speed            Int     @default(30)
  initiative       Int     @default(0)
  inspiration      Boolean @default(false)
  avatarUrl        String? // uploaded via Uploadthing
  backgroundId     String?
  gender           String?
  pronouns         String?
  notes            String?

  // Personality — populated during wizard step 8
  personalityTrait String?
  ideal            String?
  bond             String?
  flaw             String?

  // Combat state — JSON for MVP simplicity
  deathSaves Json? // { successes: 0, failures: 0 }
  hitDice    Json? // { total: 1, used: 0 }
  spellSlots Json? // { "1": { max: 2, used: 0 }, "2": { max: 0, used: 0 } }

  // Bonus overrides — additive on top of calculated values
  savingThrowBonuses Json? // { strength: 0, dexterity: 0, constitution: 0, intelligence: 0, wisdom: 0, charisma: 0 }
  skillBonuses       Json? // { acrobatics: 0, athletics: 0, ... keyed by skill index }

  // Languages — named list rather than just a count
  languages String[] @default([])

  // Conditions — enum array for type safety
  conditions Condition[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId     String
  campaignId String
  raceId     String?

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign   Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  race       Race?       @relation(fields: [raceId], references: [id])
  background Background? @relation(fields: [backgroundId], references: [id])

  abilityScores   AbilityScore?
  classes         CharacterClass[]
  features        CharacterFeature[]
  inventory       CharacterItem[]
  proficiencies   CharacterProficiency[]
  spells          CharacterSpell[]
  actionsAsActor  CombatAction[]         @relation("Actor")
  actionsAsTarget CombatAction[]         @relation("Target")

  @@index([userId])
  @@index([campaignId])
  @@index([raceId])
  @@index([backgroundId])
}

// D&D 5e standard conditions
enum Condition {
  BLINDED
  CHARMED
  DEAFENED
  EXHAUSTION
  FRIGHTENED
  GRAPPLED
  INCAPACITATED
  INVISIBLE
  PARALYZED
  PETRIFIED
  POISONED
  PRONE
  RESTRAINED
  STUNNED
  UNCONSCIOUS
}

/////////////////////////////////////////////////
// ABILITY SCORES (1-1)
/////////////////////////////////////////////////

model AbilityScore {
  id          String @id @default(uuid())
  characterId String @unique

  strength     Int @default(10)
  dexterity    Int @default(10)
  constitution Int @default(10)
  intelligence Int @default(10)
  wisdom       Int @default(10)
  charisma     Int @default(10)

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

/////////////////////////////////////////////////
// RACE & FEATURES
/////////////////////////////////////////////////

model Race {
  id          String  @id @default(uuid())
  index       String  @unique
  name        String
  speed       Int     @default(30)
  size        String?
  description String?

  abilityBonuses Json?
  traitNames     String[]

  characters Character[]
  features   Feature[]
  subraces   Subrace[]
}

model Subrace {
  id          String  @id @default(uuid())
  index       String  @unique
  name        String
  raceId      String
  description String?

  abilityBonuses Json?

  race Race @relation(fields: [raceId], references: [id], onDelete: Cascade)

  @@index([raceId])
}

model Feature {
  id          String      @id @default(uuid())
  index       String?     @unique
  name        String
  description String
  type        FeatureType

  // Combat classification — populated by seed script
  category     ActionCategory?
  actionType   ActionType?
  combatUsable Boolean         @default(false)

  raceId  String?
  classId String?

  race  Race?  @relation(fields: [raceId], references: [id])
  class Class? @relation(fields: [classId], references: [id])

  characters CharacterFeature[]

  @@index([raceId])
  @@index([classId])
}

enum FeatureType {
  CLASS
  RACE
  FEAT
  BACKGROUND
}

enum ActionCategory {
  ATTACK
  DAMAGING
  HEALING
  SUPPORT
  DEFENSIVE
  MOVEMENT
  UTILITY
}

enum ActionType {
  ACTION
  BONUS_ACTION
  REACTION
  FREE
  PASSIVE
}

model CharacterFeature {
  id          String @id @default(uuid())
  characterId String
  featureId   String

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  feature   Feature   @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([characterId, featureId])
}

/////////////////////////////////////////////////
// CLASS
/////////////////////////////////////////////////

model Class {
  id                  String  @id @default(uuid())
  index               String  @unique
  name                String
  hitDie              Int
  spellcastingAbility String?

  features   Feature[]
  characters CharacterClass[]
  subclasses Subclass[]
}

model Subclass {
  id      String @id @default(uuid())
  index   String @unique
  name    String
  classId String

  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([classId])
}

model CharacterClass {
  id          String @id @default(uuid())
  characterId String
  classId     String
  level       Int    @default(1)

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  class     Class     @relation(fields: [classId], references: [id])

  @@unique([characterId, classId])
}

/////////////////////////////////////////////////
// BACKGROUND
/////////////////////////////////////////////////

model Background {
  id          String  @id @default(uuid())
  index       String  @unique
  name        String
  description String?
  feature     String?

  skillProficiencies String[]
  languages          Int      @default(0)

  characters Character[]
}

/////////////////////////////////////////////////
// PROFICIENCIES
/////////////////////////////////////////////////

model Proficiency {
  id    String @id @default(uuid())
  index String @unique
  name  String
  type  String

  characters CharacterProficiency[]
}

model CharacterProficiency {
  id            String  @id @default(uuid())
  characterId   String
  proficiencyId String
  expertise     Boolean @default(false)

  character   Character   @relation(fields: [characterId], references: [id], onDelete: Cascade)
  proficiency Proficiency @relation(fields: [proficiencyId], references: [id])

  @@unique([characterId, proficiencyId])
  @@index([characterId])
}

/////////////////////////////////////////////////
// SPELLS
/////////////////////////////////////////////////

model Spell {
  id           String        @id @default(uuid())
  index        String        @unique
  name         String
  level        Int
  school       String
  castingTime  String
  range        String
  duration     String
  description  String
  higherLevels String?
  category     SpellCategory @default(UTILITY)

  characters    CharacterSpell[]
  combatActions CombatAction[]
}

enum SpellCategory {
  DAMAGING
  HEALING
  CONTROL
  BUFF
  DEBUFF
  UTILITY
  DEFENSE
}

model CharacterSpell {
  id          String               @id @default(uuid())
  characterId String
  spellId     String
  status      CharacterSpellStatus @default(KNOWN)

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  spell     Spell     @relation(fields: [spellId], references: [id])

  @@unique([characterId, spellId])
  @@index([characterId])
}

enum CharacterSpellStatus {
  KNOWN
  PREPARED
}

/////////////////////////////////////////////////
// ITEMS & INVENTORY
/////////////////////////////////////////////////

model Item {
  id          String   @id @default(uuid())
  index       String   @unique
  name        String
  description String?
  type        ItemType
  weight      Float?
  cost        String?

  damageDice  String?
  damageType  String?
  weaponRange String?
  armorClass  Int?

  characters CharacterItem[]
}

enum ItemType {
  WEAPON
  ARMOR
  CONSUMABLE
  TOOL
  GEAR
  MAGIC_ITEM
}

model CharacterItem {
  id          String  @id @default(uuid())
  characterId String
  itemId      String? // nullable — allows custom items not in the Item table
  quantity    Int     @default(1)
  equipped    Boolean @default(false)
  attuned     Boolean @default(false)

  // Custom item fields — used when itemId is null
  customName        String?
  customDescription String?
  customType        String?

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  item      Item?     @relation(fields: [itemId], references: [id])

  @@unique([characterId, itemId])
  @@index([characterId])
}

/////////////////////////////////////////////////
// COMBAT
/////////////////////////////////////////////////

model CombatSession {
  id         String   @id @default(uuid())
  campaignId String
  active     Boolean  @default(true)
  round      Int      @default(1)
  createdAt  DateTime @default(now())

  currentTurnCharacterId String?
  actionUsed             Boolean @default(false)
  bonusActionUsed        Boolean @default(false)
  reactionUsed           Boolean @default(false)

  campaign Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  actions  CombatAction[]

  @@index([campaignId])
  @@index([active])
}

model CombatAction {
  id          String           @id @default(uuid())
  sessionId   String
  actorId     String
  targetId    String?
  actionType  CombatActionType
  actionSlot  ActionSlot       @default(ACTION)
  spellId     String?
  attackRoll  Int?
  damageDealt Int?
  notes       String?
  createdAt   DateTime         @default(now())

  session CombatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  actor   Character     @relation("Actor", fields: [actorId], references: [id])
  target  Character?    @relation("Target", fields: [targetId], references: [id])
  spell   Spell?        @relation(fields: [spellId], references: [id])

  @@index([sessionId])
  @@index([actorId])
  @@index([targetId])
}

enum ActionSlot {
  ACTION
  BONUS_ACTION
  REACTION
  FREE
}

enum CombatActionType {
  ATTACK
  CAST
  DASH
  DODGE
  HELP
  HIDE
  READY
  OTHER
}
